<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.vigia.core.network" >

    <uses-sdk android:minSdkVersion="34" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application>

        <!--
            FCM receiver — two roles:
            1. Doze wakeup: reconnects MQTT after the radio window opens.
            2. Direct injection: delivers CRITICAL alert payloads when MQTT is unreachable.
        -->
        <service
            android:name="com.vigia.core.network.fcm.VigiaFcmReceiver"
            android:exported="false" >
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>