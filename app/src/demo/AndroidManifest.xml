<?xml version="1.0" encoding="utf-8"?>
<!--
    Demo-flavor manifest overlay.
    Sets networkSecurityConfig so cleartext HTTP is permitted to the dev ALB only.
    Merged on top of src/main/AndroidManifest.xml by the Gradle build for demoDebug/demoRelease.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
